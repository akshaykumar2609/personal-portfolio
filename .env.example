# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is git-ignored.
# ============================================================

# ---- Supabase (used by BOTH frontend and backend) ----
# Found in Supabase dashboard: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Backend uses the SERVICE ROLE key (secret — server-side only!).
# Never expose this to the browser.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Sentry ----
# Frontend DSN (Project -> Settings -> Client Keys)
VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Backend DSN (can be the same project or a separate one)
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Backend environment flag read by the Worker
ENVIRONMENT=development
