{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-10-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "production",
    "FRONTEND_URL": "https://personal-portfolio-frontend-jet.vercel.app"
  }
}
